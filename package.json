{
  "name": "browser-permissions-helper",
  "version": "4.4.0",
  "description": "A simple package to check and request browser permissions",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Your Name",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "demo:bundle": "npx --yes esbuild src/index.ts --bundle --format=esm --platform=browser --outfile=demo/library.js",
    "demo": "npm run demo:bundle && http-server demo -p 5173 -c-1",
    "demo:test": "node demo/live-test.mjs",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darshitdudhaiya/browser-permissions-helper.git"
  },
  "keywords": [
    "browser",
    "permissions",
    "helper",
    "typescript"
  ],
  "devDependencies": {
    "http-server": "14.1.1",
    "playwright": "^1.61.1",
    "typescript": "^5.8.2"
  }
}
